{
  "name": "rule-engine-js",
  "version": "1.0.0",
  "description": "A high-performance, secure rule engine with dynamic field comparison support",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.js",
  "types": "types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "browser": "./dist/index.js",
      "types": "./types/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "types/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "npm run clean && npm run build:lib && npm run build:types",
    "build:lib": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly",
    "clean": "rimraf dist types",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "lint:all": "eslint src/ tests/ --ext .js",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "rule-engine",
    "business-rules",
    "expression-evaluator",
    "conditional-logic",
    "dynamic-comparison",
    "validation",
    "filtering",
    "javascript",
    "performance"
  ],
  "author": "Crafts 69 Guy <crafts69.guy@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crafts69guy/rule-engine-js.git"
  },
  "bugs": {
    "url": "https://github.com/crafts69guy/rule-engine-js/issues"
  },
  "homepage": "https://github.com/crafts69guy/rule-engine-js#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@eslint/js": "^9.32.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^30.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.32.0",
    "jest": "^30.0.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.46.2",
    "typescript": "^5.9.2"
  }
}
