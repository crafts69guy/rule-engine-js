{
  "name": "rule-engine-js",
  "version": "1.0.3-beta.0",
  "description": "A high-performance, secure rule engine with dynamic field comparison support",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "browser": "dist/index.js",
  "types": "types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "types/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "npm run clean && npm run build:lib && npm run build:types && npm run build:analyze",
    "build:lib": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly",
    "build:analyze": "npm run analyze:bundle-size",
    "analyze:bundle-size": "node scripts/analyze-bundle.js",
    "clean": "rimraf dist types coverage",
    "test": "NODE_ENV=test jest",
    "test:watch": "jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:all-envs": "npm run test:node-versions && npm run test:imports && npm run test:bundle",
    "test:node-versions": "node scripts/test-node-versions.js",
    "test:imports": "node scripts/test-imports.js",
    "test:bundle": "npm run build && npm run test:imports:built",
    "test:imports:built": "node scripts/test-built-imports.js",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "lint:all": "eslint src/ tests/ --ext .js",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "quality:check": "node scripts/quality-check.js",
    "prepare": "husky install",
    "pre-commit": "lint-staged && npm run test:quick",
    "pre-push": "npm run test && npm run build && npm run quality:check",
    "test:quick": "npm test -- --passWithNoTests --bail",
    "prepack": "npm run quality:check && npm run build",
    "prepublishOnly": "npm run test && npm run build",
    "release:patch": "npm version patch && npm publish && git push --follow-tags",
    "release:minor": "npm version minor && npm publish && git push --follow-tags",
    "release:major": "npm version major && npm publish && git push --follow-tags"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --max-warnings 0 --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "sideEffects": false,
  "keywords": [
    "rule-engine",
    "business-rules",
    "expression-evaluator",
    "conditional-logic",
    "dynamic-comparison",
    "validation",
    "filtering",
    "javascript",
    "performance",
    "zero-dependencies",
    "typescript"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "author": "Crafts 69 Guy <crafts69.guy@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crafts69guy/rule-engine-js.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "bugs": {
    "url": "https://github.com/crafts69guy/rule-engine-js/issues"
  },
  "homepage": "https://github.com/crafts69guy/rule-engine-js#readme",
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.28.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.32.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^29.5.14",
    "cross-env": "^10.0.0",
    "eslint": "^9.32.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.46.2",
    "typescript": "^5.9.2"
  }
}
